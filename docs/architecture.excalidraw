  {
   "id": "t_path_b",
   "type": "text",
   "x": 2848,
   "y": 952,
   "width": 964,
   "height": 806,
   "angle": 0,
   "strokeColor": "#374151",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "roundness": null,
