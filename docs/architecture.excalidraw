   "isDeleted": false,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "Job 2: eval  (needs: validate)\n\n1. checkout skill-testing-playground @ main  (read-only)\n2. detect changed skill  (git diff HEAD^1)\n3. pip install -e .\n4. start mock MCP server &\n5. python -m eval.ab_compare \\\n     --skill-path <changed-skill> --trials 3\n6. post PR comment  (verdict + LangSmith trace links)\n\nSecrets: EVAL_PLATFORM_TOKEN  OPENROUTER_API_KEY\n         OPENAI_API_KEY  LANGSMITH_API_KEY",
   "fontSize": 13,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "baseline": 13,
   "containerId": null,
   "originalText": "Job 2: eval  (needs: validate)\n\n1. checkout skill-testing-playground @ main  (read-only)\n2. detect changed skill  (git diff HEAD^1)\n3. pip install -e .\n4. start mock MCP server &\n5. python -m eval.ab_compare \\\n     --skill-path <changed-skill> --trials 3\n6. post PR comment  (verdict + LangSmith trace links)\n\nSecrets: EVAL_PLATFORM_TOKEN  OPENROUTER_API_KEY\n         OPENAI_API_KEY  LANGSMITH_API_KEY",
   "lineHeight": 1.4
  },
