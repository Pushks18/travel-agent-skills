      "seed": 18, "version": 1, "versionNonce": 1, "isDeleted": false, "updated": 1, "link": null, "locked": false,
      "text": "Skill Loader  (eval/skill_loader.py)\n\nload_skill(path) → LoadedSkill\nStrips YAML frontmatter\n→ injects .body into system prompt\nFallback: plain markdown (legacy)", "fontSize": 13, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top", "baseline": 13, "containerId": null, "originalText": "", "lineHeight": 1.4
